# PathFinder-Ship example config. Copy to backend/.env and fill local values.

APP_NAME=PathFinder-Ship
DEFAULT_USER_NAME=Passenger
BOT_NAME=Passenger-Bot
DEBUG=false

API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_ORIGIN=http://localhost:5173

PHOTO_DIR=data/web_out/photo
DETECT_DIR=data/web_out/detect
MAX_FILES_PER_DIR=10

EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=465
EMAIL_USE_TLS=false
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=
EMAIL_TO_PHONE=

T5_MODEL_DIR=assets/models/t5
T5_TOKENIZER_DIR=assets/models/t5/tokenizer
T5_ENCODER=assets/models/t5/encoder_model_int8.onnx
T5_DECODER=assets/models/t5/decoder_model_int8.onnx
T5_MAX_SRC_LEN=512
T5_MAX_NEW_TOKENS_CHAT=256
T5_MAX_NEW_TOKENS_RAG=64

NLU_MODEL_DIR=assets/models/nlu
CLS_ONNX=assets/models/nlu/intent-minilm-int8.onnx
CLS_TOKENIZER_DIR=assets/models/nlu/tokenizer
CLS_MAX_LEN=64
CLS_ROUTE_THRESHOLD=0.60

YOLO_ONNX=assets/models/yolo_nas/yolo_nas_s_coco.onnx
YOLO_LABELS=assets/models/yolo_nas/labels.txt
YOLO_SIZE=640
YOLO_CONF=0.25
YOLO_IOU=0.45
YOLO_PREPROC_IN_MODEL=false

RAG_CORPUS_DIR=data/rag/corpus
UPLOAD_MAX_BYTES=10485760
RAG_UPLOAD_ALLOWED_EXTENSIONS=.pdf,.docx,.txt,.md,.html,.htm
CHROMA_PATH=assets/rag/chroma_db
RAG_SQLITE_PATH=assets/rag/chroma_db/bm25.sqlite
CHROMA_COLLECTION=pathfinder_corpus
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_SCORE_THRESHOLD=0.40
RAG_TOP_K=4
RAG_MAX_CTX_TOKENS=512
VECTOR_WEIGHT=0.75
BM25_WEIGHT=0.25
RAG_WEB_MIN_STRENGTH=0.75
WEB_CHUNK_SUPPORT_THRESHOLD=0.70

ENABLE_WEB_SEARCH=false
ENABLE_EMAIL=false
ENABLE_CAMERA_ACTIONS=true

# Backward-compatible aliases are supported in code:
# SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASSWORD, SMTP_FROM, SMTP_TO
# T5_ENCODER_ONNX, T5_DECODER_ONNX
# NLU_TOKENIZER_DIR
# YOLO_MODEL_PATH, YOLO_LABELS_PATH
# RAG_CHROMA_DIR
